.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #fdfbff; /* 浅紫色调背景，更柔和 */
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

/* Custom Header with Five Spheres */
.nav-header {
  padding: 40rpx 40rpx 20rpx;
  background: #fdfbff;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.sphere-row {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.sphere {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  box-shadow: 0 6rpx 0 rgba(0,0,0,0.05);
  position: relative;
  transition: all 0.3s;
}

.sphere.pink { background: #ff8eb3; border: 4rpx solid #fff; }
.sphere.orange { background: #ff9e4a; border: 4rpx solid #fff; }
.sphere.yellow { background: #ffdc4a; border: 4rpx solid #fff; }
.sphere.green { background: #77d37a; border: 4rpx solid #fff; }
.sphere.blue { background: #66b3ff; border: 4rpx solid #fff; }

.sphere::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 10rpx;
  height: 10rpx;
  background: rgba(255,255,255,0.4);
  border-radius: 50%;
}

.page-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #333;
  letter-spacing: 2rpx;
}

/* Filter Bar */
.filter-bar {
  padding: 0 40rpx 30rpx;
  background: #fdfbff;
}

.search-input-box {
  background: #fff;
  height: 80rpx;
  border-radius: 40rpx;
  border: 4rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 0 #f0f0f0;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.filter-options {
  display: flex;
  align-items: center;
  background: #fff;
  height: 80rpx;
  border-radius: 40rpx;
  border: 4rpx solid #f0f0f0;
  padding: 0 30rpx;
  box-shadow: 0 8rpx 0 #f0f0f0;
}

.filter-picker {
  flex: 1;
}

.picker-text {
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

.filter-divider {
  width: 2rpx;
  height: 30rpx;
  background: #eee;
  margin: 0 20rpx;
}

.city-input {
  flex: 1;
  font-size: 26rpx;
  text-align: center;
}

/* Navigation Tabs V2 */
.nav-tabs-v2 {
  display: flex;
  background: #f0f0f0;
  border-radius: 40rpx;
  padding: 8rpx;
  width: 90%;
  margin-top: 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 900;
  color: #999;
  border-radius: 36rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #fff;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* My Profile */
.my-profile-header {
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 40rpx;
  border: 4rpx solid #f0f0f0;
  box-shadow: 0 12rpx 0 #f0f0f0;
}

.user-avatar-large {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
}

.large-emoji {
  font-size: 60rpx;
}

.user-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-id {
  font-size: 36rpx;
  font-weight: 900;
  color: #333;
}

.post-count {
  font-size: 24rpx;
  color: #999;
  font-weight: 700;
}

.location-label {
  font-size: 22rpx;
  color: #66b3ff;
  font-weight: 700;
  margin-left: 10rpx;
}

/* Post Modal Picker */
.post-schedule-picker {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  border: 2rpx solid #eee;
}

.picker-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
  font-weight: 700;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 900;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 20rpx;
  color: #ccc;
}

/* Media Flow */
.media-flow {
  padding: 0 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.media-card {
  background: #fff;
  border-radius: 40rpx;
  overflow: hidden;
  border: 4rpx solid #f0f0f0;
  box-shadow: 0 12rpx 0 #f0f0f0;
}

.media-preview-box {
  position: relative;
  width: 100%;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.media-main-img {
  width: 100%;
  display: block;
}

.media-main-video {
  width: 100%;
  height: 600rpx;
}

.media-count {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.media-card-info {
  padding: 24rpx;
}

.media-card-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.media-card-footer {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.media-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.mini-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-emoji {
  font-size: 24rpx;
}

.mini-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 700;
}

.media-location {
  font-size: 22rpx;
  color: #66b3ff;
  font-weight: 700;
}

.media-likes {
  font-size: 22rpx;
  color: #ff8eb3;
  font-weight: 700;
}

/* Tour Card */
.tour-card {
  background: #fff;
  border-radius: 50rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
  border: 6rpx solid #f0f0f0;
  box-shadow: 0 16rpx 0 #f0f0f0;
  position: relative;
}

.tour-poster {
  width: 100%;
  height: 400rpx;
  background: #eee;
}

.tour-info {
  padding: 30rpx;
  position: relative;
}

.tour-status-tag {
  position: absolute;
  top: -30rpx;
  right: 30rpx;
  background: #ff8eb3;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 0 #ffb7ce;
}

.tour-name {
  font-size: 36rpx;
  font-weight: 900;
  color: #333;
  margin-bottom: 16rpx;
}

.tour-detail-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.tour-date {
  font-size: 26rpx;
  font-weight: 700;
  color: #66b3ff;
}

.tour-city {
  font-size: 26rpx;
  font-weight: 700;
  color: #77d37a;
}

.tour-venue-line {
  font-size: 24rpx;
  color: #999;
}

.tour-enter-btn {
  background: #66b3ff;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
  padding: 16rpx 0;
  border-top: 4rpx solid #f0f0f0;
}

.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Square Header New */
.square-header-new {
  padding: 0 40rpx 30rpx;
}

.back-btn {
  display: inline-flex;
  align-items: center;
  background: #fff;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  border: 4rpx solid #f0f0f0;
  box-shadow: 0 6rpx 0 #f0f0f0;
  margin-bottom: 30rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #666;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.current-schedule-info-v2 {
  background: #fff;
  padding: 30rpx 40rpx;
  border-radius: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 0rpx #f0f0f0;
  border: 4rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.current-schedule-info {
  background: #fff;
  padding: 30rpx 40rpx;
  border-radius: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 0rpx #f0f0f0;
  border: 4rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  position: relative;
  overflow: hidden;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.live-indicator {
  font-size: 18rpx;
  font-weight: 900;
  color: #fff;
  background: #ff8eb3;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.6; }
  100% { opacity: 1; }
}

.current-schedule-info::before {
  content: 'STATION';
  position: absolute;
  right: -20rpx;
  top: 10rpx;
  font-size: 60rpx;
  font-weight: 900;
  color: rgba(0,0,0,0.03);
  transform: rotate(-15deg);
}

.location-tag {
  font-size: 24rpx;
  color: #66b3ff;
  font-weight: 900;
}

.schedule-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
}

.quick-post-bar {
  background: #fff;
  padding: 24rpx 36rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 0rpx #f0f0f0;
  border: 4rpx solid #f0f0f0;
}

.user-avatar-mini {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f9faff;
  margin-right: 24rpx;
  border: 2rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-emoji {
  font-size: 28rpx;
}

.post-btn-mini {
  background: #66b3ff;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 0 #4a9eff;
}

.placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #bbb;
  font-weight: 500;
}

.icon-camera {
  font-size: 36rpx;
}

.feed-list {
  display: flex;
  flex-direction: column;
}

.feed-section-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 10rpx;
}

.feed-item {
  background: #fff;
  border-radius: 48rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 0rpx #f0f0f0;
  border: 4rpx solid #f0f0f0;
  position: relative;
}

.item-decoration {
  position: absolute;
  top: 0;
  right: 60rpx;
  background: #ffdc4a;
  color: #856404;
  font-size: 16rpx;
  font-weight: 900;
  padding: 4rpx 16rpx;
  border-radius: 0 0 16rpx 16rpx;
  border: 4rpx solid #ffdc4a;
  border-top: none;
}

.official-post {
  border-color: #ffdc4a;
  box-shadow: 0 12rpx 0rpx #fff5cc;
  background: linear-gradient(180deg, #fff, #fffef5);
}

.feed-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 30rpx; /* 卡通风圆角矩形头像 */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 6rpx 0rpx rgba(0,0,0,0.05);
  border: 4rpx solid #fff;
}

.avatar-emoji {
  font-size: 48rpx;
}

.user-info {
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #333;
}

.official-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  background: #ffdc4a;
  color: #856404;
  border-radius: 12rpx;
  font-weight: 900;
}

.post-time {
  font-size: 24rpx;
  color: #ccc;
  font-weight: 500;
}

.feed-content {
  font-size: 30rpx;
  color: #444;
  line-height: 1.6;
  margin-bottom: 30rpx;
  display: block;
  font-weight: 500;
}

/* Media Display */
.feed-media-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.feed-media-list.single {
  display: block;
}

.media-item {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f8f9fb;
  border: 2rpx solid #f0f0f0;
}

.media-img {
  width: 100%;
  height: 220rpx;
  display: block;
}

.single .media-img {
  max-width: 90%;
  height: auto;
  border-radius: 32rpx;
  border: 4rpx solid #f0f0f0;
}

.media-video {
  width: 100%;
  height: 220rpx;
}

.video-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-play {
  color: #fff;
  font-size: 48rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.feed-footer {
  display: flex;
  justify-content: flex-end;
  gap: 50rpx;
  padding-top: 30rpx;
  border-top: 4rpx dashed #f8f8f8;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #bbb;
  font-weight: 800;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.action-item:active {
  background: #f8f9fb;
  transform: scale(0.95);
}

.action-item.liked {
  color: #ff8eb3;
}

.action-item.liked .icon {
  animation: heartBeat 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

.replies-box {
  background: #f9faff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-top: 30rpx;
  border: 2rpx solid #f0f3ff;
}

.reply-item {
  font-size: 26rpx;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-user {
  color: #66b3ff;
  font-weight: 800;
}

.reply-text {
  color: #666;
  font-weight: 500;
}

/* FAB Post */
.fab-post {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 120rpx;
  height: 120rpx;
  background: #66b3ff;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 0rpx #4a9eff; /* 卡通厚阴影 */
  color: #fff;
  z-index: 99;
  transition: all 0.2s;
  border: 6rpx solid #fff;
}

.fab-post:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 0rpx #4a9eff;
}

.fab-icon {
  font-size: 60rpx;
  font-weight: 900;
  line-height: 1;
}

.fab-text {
  font-size: 20rpx;
  font-weight: 900;
}

/* Modal */
.post-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1000;
  visibility: hidden;
}

.post-modal.show {
  visibility: visible;
}

.modal-mask {
  position: absolute;
  width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s;
}

.show .modal-mask {
  opacity: 1;
}

.modal-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 60rpx 60rpx 0 0;
  padding: 60rpx 48rpx;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.18, 0.89, 0.32, 1.2);
  border-top: 8rpx solid #f0f0f0;
}

.modal-decoration {
  position: absolute;
  top: -40rpx;
  left: 60rpx;
  width: 80rpx;
  height: 80rpx;
  background: #ff8eb3;
  color: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 900;
  transform: rotate(-15deg);
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 0 #ffb7ce;
}

.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 38rpx;
  font-weight: 900;
}

.close-btn {
  font-size: 56rpx;
  color: #eee;
  padding: 10rpx;
  font-weight: 300;
}

.post-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
  background: #f9f9f9;
  border-radius: 30rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.post-media-picker {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-bottom: 60rpx;
}

.picker-item {
  height: 150rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: #f8f9fb;
  border: 2rpx solid #f0f0f0;
}

.picker-item image, .picker-item video {
  width: 100%; height: 100%;
}

.remove-btn {
  position: absolute;
  top: 0; right: 0;
  width: 44rpx; height: 44rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 0 0 0 20rpx;
}

.add-btn {
  border: 4rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
  font-weight: bold;
}

.add-text {
  font-size: 20rpx;
  color: #ccc;
  font-weight: 800;
}

.post-btn {
  width: 100% !important;
  background: #66b3ff;
  color: #fff;
  border-radius: 60rpx;
  font-size: 34rpx;
  font-weight: 900;
  padding: 32rpx 0;
  box-shadow: 0 12rpx 0rpx #4a9eff;
  margin-bottom: 20rpx;
}

.post-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 0rpx #4a9eff;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  color: #ccc;
  font-size: 30rpx;
  font-weight: 500;
}