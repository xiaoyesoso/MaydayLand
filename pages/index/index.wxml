<view class="container">
  <!-- Header -->
  <view class="nav-header" wx:if="{{!showSquare}}">
    <view class="sphere-row">
      <view class="sphere pink"></view>
      <view class="sphere orange"></view>
      <view class="sphere yellow"></view>
      <view class="sphere green"></view>
      <view class="sphere blue"></view>
    </view>
    
    <view class="nav-tabs-v2">
      <view class="tab-item {{currentTab === 'schedule' ? 'active' : ''}}" bindtap="switchTab" data-tab="schedule">巡演日程</view>
      <view class="tab-item {{currentTab === 'media' ? 'active' : ''}}" bindtap="switchTab" data-tab="media">动态广场</view>
      <view class="tab-item {{currentTab === 'my' ? 'active' : ''}}" bindtap="switchTab" data-tab="my">我的动态</view>
    </view>
  </view>

  <!-- Filter Bar (Only show in list view) -->
  <view class="filter-bar" wx:if="{{currentTab === 'schedule' && !showSquare}}">
    <view class="search-input-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索巡演名称/场馆" bindinput="onFilterInput" value="{{filterKeyword}}" />
    </view>
    <view class="filter-options">
      <picker class="filter-picker" mode="date" fields="month" bindchange="onFilterDate">
        <view class="picker-text">{{filterDate ? filterDate : '选择月份'}}</view>
      </picker>
      <view class="filter-divider"></view>
      <input class="city-input" placeholder="输入城市" bindinput="onFilterCity" value="{{filterCity}}" />
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y bindscroll="onScroll" scroll-top="{{scrollTop}}" scroll-with-animation>
    <!-- Schedule Tab View -->
    <view class="tab-content" wx:if="{{currentTab === 'schedule' && !showSquare}}">
      <view class="welcome-section">
        <view class="cartoon-badge">MAYDAY</view>
        <text class="welcome-title">回到那一天</text>
        <text class="welcome-subtitle">25TH ANNIVERSARY TOUR</text>
      </view>
      
      <view class="schedule-list">
        <view class="tour-card" wx:for="{{filteredSchedule}}" wx:key="id" bindtap="selectSchedule" data-id="{{item.id}}">
          <image class="tour-poster" src="{{item.poster}}" mode="aspectFill"></image>
          <view class="tour-info">
            <view class="tour-status-tag">{{item.status}}</view>
            <view class="tour-name">{{item.tourName}}</view>
            <view class="tour-detail-row">
              <text class="tour-date">{{item.date}}</text>
              <text class="tour-city">{{item.city}}</text>
            </view>
            <view class="tour-venue-line">📍 {{item.venue}}</view>
          </view>
          <view class="tour-enter-btn">进入广场</view>
        </view>

        <view class="empty-state" wx:if="{{filteredSchedule.length === 0}}">
          <text class="empty-text">没有找到符合条件的巡演~</text>
        </view>
      </view>
    </view>

    <!-- Media Square Tab View -->
    <view class="tab-content" wx:if="{{currentTab === 'media'}}">
      <view class="media-flow">
        <view class="media-card" wx:for="{{mediaFeed}}" wx:key="id">
          <!-- Media Content (Big Image/Video) -->
          <view class="media-preview-box" catchtap="previewImage" data-url="{{item.images[0].url}}" data-list="{{item.images}}">
            <image wx:if="{{item.images[0].type === 'image'}}" src="{{item.images[0].url}}" mode="widthFix" class="media-main-img" lazy-load></image>
            <video wx:if="{{item.images[0].type === 'video'}}" src="{{item.images[0].url}}" class="media-main-video" show-center-play-btn="{{false}}" muted="{{true}}"></video>
            <view class="media-count" wx:if="{{item.images.length > 1}}">+{{item.images.length}}</view>
          </view>
          
          <!-- Media Info -->
          <view class="media-card-info">
            <text class="media-card-text">{{item.content || item.text}}</text>
            <view class="media-card-footer">
              <view class="media-user">
                <view class="mini-avatar" style="background-color: {{item.avatarColor}}">
                  <text class="mini-emoji">{{item.emoji}}</text>
                </view>
                <text class="mini-name">{{item.author}}</text>
              </view>
              <view class="media-location">📍 {{item.cityName}}</view>
              <view class="media-likes">❤️ {{item.likes}}</view>
            </view>
          </view>
        </view>
        
        <view class="empty-state" wx:if="{{mediaFeed.length === 0}}">
          <text class="empty-text">这里还没有带图动态，快去发布第一条吧~</text>
        </view>
      </view>
    </view>

    <!-- My Feed Tab View -->
    <view class="tab-content" wx:if="{{currentTab === 'my'}}">
      <view class="my-profile-header">
        <view class="user-avatar-large" style="background-color: {{getUserStyle(userId).color}}">
          <text class="large-emoji">{{getUserStyle(userId).emoji}}</text>
        </view>
        <view class="user-stats">
          <text class="user-id">五迷_{{userId ? userId.substr(-4) : '匿名'}}</text>
          <text class="post-count">共发布 {{myFeed.length}} 条动态</text>
        </view>
      </view>

      <view class="feed-list">
        <view class="feed-item" wx:for="{{myFeed}}" wx:key="id">
          <view class="feed-header">
            <view class="user-avatar" style="background-color: {{item.avatarColor}}">
              <text class="avatar-emoji">{{item.emoji}}</text>
            </view>
            <view class="user-info">
              <view class="user-name-row">
                <text class="user-name">{{item.author}}</text>
                <text class="location-label">📍 {{item.cityName}}</text>
              </view>
              <text class="post-time">{{item.time}}</text>
            </view>
          </view>

          <text class="feed-content">{{item.text || item.content}}</text>

          <!-- Media Display -->
          <view class="feed-media-list {{item.images.length === 1 ? 'single' : ''}}" wx:if="{{item.images && item.images.length > 0}}">
            <view class="media-item" wx:for="{{item.images}}" wx:for-item="media" wx:key="url" catchtap="previewImage" data-url="{{media.url}}" data-list="{{item.images}}">
              <image wx:if="{{media.type === 'image'}}" src="{{media.url}}" mode="{{item.images.length === 1 ? 'widthFix' : 'aspectFill'}}" class="media-img" lazy-load></image>
              <video wx:if="{{media.type === 'video'}}" src="{{media.url}}" class="media-video" show-center-play-btn="{{false}}" muted="{{true}}"></video>
            </view>
          </view>

          <view class="feed-footer">
            <view class="action-item {{item.isLiked ? 'liked' : ''}}">
              <text class="icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
              <text>{{item.likes || 0}}</text>
            </view>
            <view class="action-item">
              <text class="icon">💬</text>
              <text>{{item.replies ? item.replies.length : 0}}</text>
            </view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{myFeed.length === 0}}">
          <text class="empty-text">你还没有发布过动态哦~</text>
        </view>
      </view>
    </view>

    <!-- Square View -->
    <view class="tab-content" wx:if="{{showSquare}}">
      <view class="square-header-new">
        <view class="back-btn" bindtap="goBackToList">
          <text class="back-icon">←</text>
          <text>返回列表</text>
        </view>
        <view class="current-schedule-info-v2" wx:if="{{selectedSchedule}}">
          <view class="info-top">
            <text class="location-tag">📍 {{selectedSchedule.venue}}</text>
            <view class="live-indicator">LIVE</view>
          </view>
          <text class="schedule-name">{{selectedSchedule.tourName}} · {{selectedSchedule.city}}站</text>
        </view>
        
        <view class="quick-post-bar" bindtap="openPostModal">
          <view class="user-avatar-mini">
            <text class="mini-emoji">🎸</text>
          </view>
          <text class="placeholder">大家都在聊什么？点击分享...</text>
          <view class="post-btn-mini">发布</view>
        </view>
      </view>

      <view class="feed-list">
        <view class="feed-section-title">✨ 精彩动态</view>
        <view class="feed-item {{item.type === 'official' ? 'official-post' : ''}}" wx:for="{{squareFeed}}" wx:key="id">
          <!-- Item Decoration -->
          <view class="item-decoration" wx:if="{{item.type === 'official'}}">OFFICIAL</view>
          <view class="feed-header">
            <view class="user-avatar" style="background-color: {{item.avatarColor || '#eee'}}">
              <text class="avatar-emoji">{{item.emoji || '🎸'}}</text>
            </view>
            <view class="user-info">
              <view class="user-name-row">
                <text class="user-name">{{item.author || '五迷'}}</text>
                <text class="official-tag" wx:if="{{item.type === 'official'}}">官方</text>
              </view>
              <text class="post-time">{{item.time}}</text>
            </view>
          </view>

          <text class="feed-content">{{item.text || item.content}}</text>

          <!-- Media Display -->
          <view class="feed-media-list {{item.images.length === 1 ? 'single' : ''}}" wx:if="{{item.images && item.images.length > 0}}">
            <view class="media-item" wx:for="{{item.images}}" wx:for-item="media" wx:key="url" catchtap="previewImage" data-url="{{media.url}}" data-list="{{item.images}}">
              <image wx:if="{{media.type === 'image'}}" src="{{media.url}}" mode="{{item.images.length === 1 ? 'widthFix' : 'aspectFill'}}" class="media-img" lazy-load></image>
              <video wx:if="{{media.type === 'video'}}" src="{{media.url}}" class="media-video" show-center-play-btn="{{false}}" muted="{{true}}"></video>
              <view wx:if="{{media.type === 'video'}}" class="video-overlay">
                <text class="icon-play">▶</text>
              </view>
            </view>
          </view>

          <view class="feed-footer">
            <view class="action-item {{item.isLiked ? 'liked' : ''}}" catchtap="toggleLike" data-id="{{item.id}}">
              <text class="icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
              <text>{{item.likes || 0}}</text>
            </view>
            <view class="action-item" catchtap="startReply" data-id="{{item.id}}" data-name="{{item.author}}">
              <text class="icon">💬</text>
              <text>{{item.replies ? item.replies.length : 0}}</text>
            </view>
          </view>

          <!-- Replies Section -->
          <view class="replies-box" wx:if="{{item.replies && item.replies.length > 0}}">
            <view class="reply-item" wx:for="{{item.replies}}" wx:for-item="reply" wx:key="id">
              <text class="reply-user">{{reply.userName}}</text>
              <text class="reply-text">: {{reply.text}}</text>
            </view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{squareFeed.length === 0}}">
          <text class="empty-text">这里还没有动态，快去发布吧~</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- FAB Post Button -->
  <view class="fab-post" wx:if="{{showSquare || currentTab === 'media' || currentTab === 'my'}}" bindtap="openPostModal">
    <text class="fab-icon">+</text>
    <text class="fab-text">发布</text>
  </view>

  <!-- Post Modal -->
  <view class="post-modal {{showPostModal ? 'show' : ''}}">
    <view class="modal-mask" bindtap="closePostModal"></view>
    <view class="modal-content">
      <view class="modal-decoration">♪</view>
      <view class="modal-header">
        <text class="modal-title">{{replyingToId ? '✨ 回复动态' : '🚀 发布动态'}}</text>
        <text class="close-btn" bindtap="closePostModal">×</text>
      </view>
      
      <!-- Schedule Picker (Show when posting from Global Square or My Feed) -->
      <view class="post-schedule-picker" wx:if="{{!replyingToId}}">
        <text class="picker-label">关联巡演日程：</text>
        <picker bindchange="onPostScheduleChange" value="{{postScheduleIndex}}" range="{{schedule}}" range-key="city">
          <view class="picker-value">
            {{schedule[postScheduleIndex].city}}站 · {{schedule[postScheduleIndex].tourName}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      
      <textarea class="post-textarea" 
                placeholder="{{replyingToId ? '回复 @' + replyingToName + '...' : '分享此刻心情...'}}" 
                bindinput="onInputComment" 
                value="{{commentText}}"
                focus="{{showPostModal}}"
                maxlength="500"></textarea>

      <!-- Media Picker -->
      <view class="post-media-picker" wx:if="{{!replyingToId}}">
        <view class="picker-item" wx:for="{{tempImages}}" wx:key="url">
          <image wx:if="{{item.type === 'image'}}" src="{{item.url}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.url}}" data-list="{{tempImages}}"></image>
          <video wx:if="{{item.type === 'video'}}" src="{{item.url}}" show-center-play-btn="{{false}}" muted></video>
          <view class="remove-btn" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view class="picker-item add-btn" bindtap="chooseImage" wx:if="{{tempImages.length < 9}}">
          <text class="add-icon">+</text>
          <text class="add-text">图片/视频</text>
        </view>
      </view>

      <view class="post-footer">
        <button class="post-btn" bindtap="sendComment">确认发布</button>
      </view>
    </view>
  </view>
</view>